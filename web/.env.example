# Copy this file to `.env.local` (gitignored) and fill in values.
# Vite only exposes env vars prefixed with VITE_ to client code.

# Base URL of the Poneglyph API. No trailing slash.
# Local dev:       VITE_API_BASE_URL=http://localhost:8000
# Prod (Railway):  VITE_API_BASE_URL=https://poneglyph-production-dfaf.up.railway.app
VITE_API_BASE_URL=http://localhost:8000

# Cloudflare Turnstile site key (public). Pair with TURNSTILE_SECRET_KEY
# on the backend. The site key is safe to commit / expose — only the
# secret is sensitive.
# Dev tip: if TURNSTILE_ENABLED=false on the backend, this can be any
# dummy string and the widget's token is ignored.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADCC3pXeAWpkFhMQ
