# === Neo4j — API layer ==========================================
# The API honors a local/aura toggle via NEO4J_ENV. Ingest/pipeline
# scripts always use the legacy NEO4J_URI block below (they only
# ever target local; Aura is populated via dump-upload, not ingest).

# Which Neo4j backend the API uses: "local" or "aura"
NEO4J_ENV=local

# Local Neo4j (Neo4j Desktop)
NEO4J_LOCAL_URI=bolt://localhost:7687
NEO4J_LOCAL_USER=neo4j
NEO4J_LOCAL_PASSWORD=your-local-neo4j-password

# Neo4j Aura (production) — get from https://console.neo4j.io
# URI scheme is neo4j+s:// (not bolt://). Username + database name are the
# instance ID on Aura Free; password shown exactly once at create time.
NEO4J_AURA_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_AURA_USER=<instance-id>
NEO4J_AURA_PASSWORD=your-aura-password
NEO4J_AURA_DATABASE=<instance-id>

# === Neo4j — ingest/pipeline scripts ============================
# These are read directly by ingest/*.py and pipeline/*.py via os.getenv.
# Always point at local — Aura is populated via dump-upload (Stage 1 of
# the deploy workflow), never re-ingested.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-local-neo4j-password

# === Anthropic ==================================================
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# === FastAPI / security =========================================
# Dev: ALLOWED_ORIGINS=http://localhost:3000
# Prod: comma-separated list, e.g. https://poneglyph.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare Turnstile — https://dash.cloudflare.com → Turnstile
# Dev: leave TURNSTILE_ENABLED=false to bypass
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_ENABLED=false

# Admin monitoring endpoint — curl -H "X-Admin-Token: ..." /api/admin/stats
ADMIN_TOKEN=your-admin-token
