# Neo4j connection — local dev uses bolt://localhost:7687
# Production uses Neo4j Aura: bolt+ssc://<id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Anthropic — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# FastAPI / security
# Dev: ALLOWED_ORIGINS=http://localhost:3000
# Prod: ALLOWED_ORIGINS=https://poneglyph.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare Turnstile — https://dash.cloudflare.com → Turnstile
# Dev: leave TURNSTILE_ENABLED=false to bypass
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_ENABLED=false

# Admin monitoring endpoint — curl -H "X-Admin-Token: ..." /api/admin/stats
ADMIN_TOKEN=your-admin-token
