# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# Values with special shell chars (#, $, !, spaces) should be wrapped in
# double quotes — Python loads this file fine either way, but `source .env`
# from zsh/bash breaks on unquoted special chars.

# ============================================================================
# Neo4j — API layer (api/*)
# ============================================================================
# The API reads these via api/config.py (pydantic-settings) and picks between
# LOCAL and AURA based on NEO4J_ENV below. Never read directly via os.getenv.

# Which Neo4j backend the API uses: "local" or "aura"
NEO4J_ENV=local

# Local Neo4j (Neo4j Desktop) — bolt://, no TLS
NEO4J_LOCAL_URI=bolt://localhost:7687
NEO4J_LOCAL_USER=neo4j
NEO4J_LOCAL_PASSWORD="your-local-neo4j-password"

# Neo4j Aura (production) — get from https://console.neo4j.io
# URI scheme is neo4j+s:// (or neo4j+ssc:// for self-signed).
# On Aura Free the USER + DATABASE are the instance ID (not "neo4j").
# Password is shown exactly once at create time — if lost, you must reset.
NEO4J_AURA_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_AURA_USER=<instance-id>
NEO4J_AURA_PASSWORD="your-aura-password"
NEO4J_AURA_DATABASE=<instance-id>

# All other Neo4j consumers (query/ask.py, ingest/*.py, pipeline/*.py,
# fixes/*.py, tests/run_stress_test.py, utils/generate_schema.py) read via
# utils/neo4j_env.py, which honors the same NEO4J_ENV toggle above.
#
# To retarget the stress test (or any CLI script) at Aura for one run:
#   NEO4J_ENV=aura python3 tests/run_stress_test.py 7

# ============================================================================
# Anthropic
# ============================================================================
# Get from https://console.anthropic.com. Set a monthly spend cap + email
# alert in the console before pointing public traffic at the API.
ANTHROPIC_API_KEY=sk-ant-...

# ============================================================================
# FastAPI / security
# ============================================================================
# Dev: http://localhost:3000  (or http://localhost:5173 for Vite)
# Prod: comma-separated list, e.g. https://poneglyph.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare Turnstile — https://dash.cloudflare.com → Turnstile
# Dev: leave TURNSTILE_ENABLED=false to bypass bot verification.
# Prod: set to true AND provide the secret key below.
TURNSTILE_SECRET_KEY="your-turnstile-secret-key"
TURNSTILE_ENABLED=false

# Admin monitoring endpoint — curl -H "X-Admin-Token: ..." /api/admin/stats
ADMIN_TOKEN="your-admin-token"

# Per-IP rate limit on /api/ask (requests per hour per IP).
# Default 10 is conservative; bump to 30 once Turnstile is verified
# working on the deployed frontend (see api/middleware/rate_limit.py).
RATE_LIMIT_PER_HOUR=10
